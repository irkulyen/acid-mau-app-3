NODE_ENV=development
PORT=3000

# Required in production.
# Supports exact origins and wildcard patterns with "*" (e.g. https://*.expo.dev).
# Example for external dev/tunnel usage:
# CORS_ALLOWED_ORIGINS=https://your-app.example.com,https://*.expo.dev,https://*.exp.direct
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,https://*.expo.dev,https://*.exp.direct,https://*.manus.space

# Optional: enable Redis-backed realtime state store
# REDIS_URL=redis://localhost:6379
#
# In production, keep this enabled to prevent split-brain multiplayer state.
ENFORCE_SINGLE_SOCKET_INSTANCE=true
SINGLE_SOCKET_LOCK_TTL_SEC=45
ROOM_RECONCILE_INTERVAL_MS=60000
# Optional: protect /api/telemetry with Bearer token
TELEMETRY_TOKEN=
SERVER_BUILD_ID=dev
# Comma-separated numeric user IDs with admin socket privileges (server-side only).
ADMIN_USER_IDS=

# Database / Auth
DATABASE_URL=mysql://root:root@127.0.0.1:3306/crazyamsel
JWT_SECRET=your-secret-key-change-in-production
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Gameplay feature flags.
# Keep disabled by default until the developer explicitly specifies the behavior.
ENABLE_BOTS=false
ENABLE_BLACKBIRD_EVENTS=false
ENABLE_AUTO_DRAW_FOR_DISCONNECTED_PLAYERS=false
ENABLE_AUTO_READY_ON_ROUND_END=false
ENABLE_AUTO_NEXT_ROUND=false

# Ruleset guard. Enable in CI/production when only explicitly approved rules should run.
ENFORCE_EXPLICIT_RULESET=false
# Example: RULESET_ID=crazy-amsel-ruleset-v1
RULESET_ID=
